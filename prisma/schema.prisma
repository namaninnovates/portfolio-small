generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Work {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String
  tags        String   // Storing as JSON string or comma-separated for SQLite simplicity
  projectUrl  String?
  liveUrl     String?
  tools       String   // Storing tools/tech as comma separated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
